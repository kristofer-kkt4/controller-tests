<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.example.ui.controllers.LoginController"
           styleClass="root-pane">
    <VBox styleClass="login-card" alignment="CENTER" spacing="0">
        <VBox alignment="CENTER" styleClass="login-header" spacing="8">
            <Label text="✈" styleClass="login-icon"/>
            <Label text="TripPlanner" styleClass="login-title"/>
            <Label text="Your journey starts here" styleClass="login-subtitle"/>
        </VBox>
        <VBox styleClass="login-form" spacing="14">
            <Label text="EMAIL" styleClass="field-label"/>
            <TextField fx:id="emailField" promptText="you@example.com" styleClass="text-field"/>
            <Label text="PASSWORD" styleClass="field-label"/>
            <PasswordField fx:id="passwordField" promptText="••••••••" styleClass="text-field"/>
            <Label fx:id="errorLabel" styleClass="error-label" text="" wrapText="true"/>
            <Button text="Sign In" onAction="#handleLogin" styleClass="btn-primary" maxWidth="Infinity"/>
            <Separator/>
            <HBox alignment="CENTER" spacing="6">
                <Label text="No account?" styleClass="muted-label"/>
                <Hyperlink text="Register here" onAction="#goToRegister" styleClass="link"/>
            </HBox>
            <VBox styleClass="hint-box" spacing="4" alignment="CENTER">
                <Label text="DEMO CREDENTIALS" styleClass="hint-title"/>
                <Label text="User:    test@test.com  /  1234" styleClass="hint-text"/>
                <Label text="Admin:  admin@test.com  /  admin" styleClass="hint-text"/>
            </VBox>
        </VBox>
    </VBox>
</StackPane>
